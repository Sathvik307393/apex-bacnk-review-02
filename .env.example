# NexaBank — Environment Configuration
# Copy this file to .env for local development.
# In Azure, all secrets are stored in Key Vault and injected as Container App environment variables.

# ===== ENVIRONMENT =====
NODE_ENV=production

# ===== DATABASE =====
# Local Docker: use 'db' as the host
# Azure:        use the PostgreSQL Flexible Server FQDN (e.g. nexabank-postgres.postgres.database.azure.com)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=SecurePass123!@
DB_NAME=apex_bank
# Set to true when connecting to Azure PostgreSQL (SSL required)
DB_SSL=false

# ===== AUTHENTICATION =====
JWT_SECRET=apex_banking_super_secret_cryptographic_key_9988
JWT_EXPIRY=2h

# ===== FILE UPLOADS =====
# Local fallback directory (only used when AZURE_STORAGE_CONNECTION_STRING is NOT set)
UPLOAD_DIR=./uploads
JSON_DB_PATH=./database.json

# ===== AZURE STORAGE =====
# Obtain from: Azure Portal > Storage Account > Access Keys > Connection string
# When set, KYC files are stored in Azure Blob Storage instead of local disk
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=

# ===== AZURE KEY VAULT (optional - for managed identity auth) =====
AZURE_KEY_VAULT_URL=

# ===== EMAIL SERVICE (Optional) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM_NAME=NexaBank
SMTP_FROM_EMAIL=security@nexabank.com

# ===== INTERNAL SERVICE URLs =====
# Local Docker Compose: use service names
# Azure Container Apps:  use http://<container-app-name>
AUTH_SERVICE_URL=http://auth:3001
USER_SERVICE_URL=http://user:3002
TRANSACTION_SERVICE_URL=http://transactions:3003
KYC_SERVICE_URL=http://kyc:3004
AUDIT_SERVICE_URL=http://audit:3006
ADMIN_SERVICE_URL=http://admin:3007
DOC_PROCESSOR_URL=http://doc-processor:3005

# ===== CORS CONFIGURATION =====
# Set to your Azure Container App public URL in production
CORS_ORIGIN=*

# ===== LOGGING =====
LOG_LEVEL=info
